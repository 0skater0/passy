# ======================================================================
# Passy configuration
# ======================================================================
# Copy this file to `.env` and fill in the values that apply to you.
# Everything is optional unless a variable is marked (required).
#
# Three broad setups are supported. Pick one and skim the matching block:
#   1. Frontend-only    — just the generator, no server state, no accounts.
#                         Set ENABLE_BACKEND=false. You can also just open
#                         the hosted build at https://0skater0.github.io/passy/
#                         and ignore this file entirely.
#
#   2. Self-hosted (no accounts)
#                       — full app, no user accounts. ENABLE_BACKEND=true,
#                         ENABLE_ACCOUNTS=false. Optional HIBP lookup,
#                         server-side history is disabled.
#
#   3. Self-hosted (with accounts)
#                       — full app with signup, login, TOTP and optional
#                         OIDC. ENABLE_BACKEND=true, ENABLE_ACCOUNTS=true,
#                         JWT_SECRET and APP_URL filled in, a database
#                         reachable, and an SMTP relay for password reset.
# ======================================================================


# ----------------------------------------------------------------------
# Core
# ----------------------------------------------------------------------

# HTTP listen port of the Node process.
PORT=8080

# URL path prefix when the app is reverse-proxied under a sub-path, e.g.
# `/passy`. Leave as `/` when the app is mounted at the root of a host.
BASE_PATH=/

# true  = full app, API available, optional accounts.
# false = pure client-side generator, no API, no server state.
ENABLE_BACKEND=true

# Log level for the Node process. One of: error, warn, info, debug.
LOG_LEVEL=info


# ----------------------------------------------------------------------
# Accounts and auth
#
# Only read when ENABLE_BACKEND=true. Turn ENABLE_ACCOUNTS off to run the
# server as a stateless generator that still serves the SPA + optional
# Pwned lookup but has no users, no history, no admin panel.
# ----------------------------------------------------------------------

# Turn signup and login on. Implies that a database is reachable.
ENABLE_ACCOUNTS=false

# Public registration. Typical flow: turn this on, register your own
# account, promote yourself to admin in the DB, then flip it back to
# false so the world cannot sign up on your instance.
ENABLE_SIGNUP=false

# (required when ENABLE_ACCOUNTS=true)
# Long random string used to sign session JWTs. Rotating it signs every
# user out instantly. Generate one with e.g.
#     openssl rand -base64 48
JWT_SECRET=

# (required when ENABLE_ACCOUNTS=true)
# Public base URL where the app is reachable. Used to build password-
# reset links and — unless OIDC_REDIRECT_URI is set explicitly — to
# derive the OIDC callback URL.
APP_URL=https://passy.example.com


# ----------------------------------------------------------------------
# Database
#
# Only read when ENABLE_ACCOUNTS=true or when Pwned caching is on.
# Picks Postgres when DATABASE_URL or POSTGRES_HOST is set, otherwise
# falls back to SQLite. DB_TYPE lets you force one or the other.
# ----------------------------------------------------------------------

# Force a specific backend: `postgres` or `sqlite`. Leave commented to
# auto-detect from DATABASE_URL / POSTGRES_HOST.
# DB_TYPE=postgres

# Option 1 — single Postgres connection string. Wins over the discrete
# vars below if set.
# DATABASE_URL=postgresql://passy:passy@db:5432/passy

# Option 2 — discrete Postgres vars. Leave POSTGRES_HOST empty to use
# SQLite instead.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=passy
POSTGRES_USER=passy
POSTGRES_PASSWORD=

# SQLite file path. Only used when DB_TYPE=sqlite (or when no Postgres
# config is present). Must be writable by the Node process.
# SQLITE_PATH=/data/passy.sqlite


# ----------------------------------------------------------------------
# OIDC / single sign-on (optional)
#
# Leave every variable in this block empty to disable OIDC. When set,
# an "Sign in with SSO" button appears next to the local login form.
# ----------------------------------------------------------------------

# Discovery URL of the OIDC provider, e.g.
#     https://auth.example.com
# The app reads the well-known endpoints from <issuer>/.well-known/openid-configuration
OIDC_ISSUER_URL=

OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Scopes to request. Most providers need at least these three.
OIDC_SCOPES=openid profile email

# Callback URL registered with the OIDC provider. Leave empty to
# auto-derive it from APP_URL as `<APP_URL>/api/auth/oidc/callback`.
# Set it explicitly when the public URL does not match APP_URL (e.g.
# behind a reverse proxy that rewrites paths).
OIDC_REDIRECT_URI=

# When true, an OIDC sign-in whose email matches an existing local
# account auto-links the two — the user keeps their history and admin
# flag. When false, OIDC sign-ins and local accounts stay separate.
OIDC_AUTO_LINK_BY_EMAIL=false


# ----------------------------------------------------------------------
# SMTP / outgoing email (optional)
#
# Needed for password-reset emails. Leave SMTP_HOST empty to disable
# email entirely — password reset then becomes an admin-only action.
# ----------------------------------------------------------------------

# Relay hostname or IP. Leave empty to disable outgoing email.
SMTP_HOST=

# 25   = plain SMTP (internal relays)
# 587  = STARTTLS (most public providers)
# 465  = implicit TLS
SMTP_PORT=587

# Leave empty for unauthenticated internal relays.
SMTP_USER=
SMTP_PASS=

# Sender address. Validated on startup against RFC 5322 and a list of
# known placeholder patterns — the process refuses to start with an
# address like `change-me@example.com` or an empty value. Format can be
# either a bare address or `Display Name <address@example.com>`.
SMTP_FROM=


# ----------------------------------------------------------------------
# Have I Been Pwned lookup (optional)
#
# When on, the strength meter flags passwords that appear in the HIBP
# breach corpus. Prefix files are cached locally so cleartext passwords
# never leave your server.
# ----------------------------------------------------------------------

ENABLE_PWNED=false

# Directory where the 5-char hash-prefix files are cached.
PWNED_DATA_DIR=/data/pwned

# When true, the server fetches missing or expired prefix files from the
# public HIBP range API on demand. When false, only pre-seeded files are
# used and unknown prefixes are skipped.
PWNED_LAZY_FETCH=true

# Cache lifetime for each prefix file, in hours. 168 = 7 days.
PWNED_TTL_HOURS=168


# ----------------------------------------------------------------------
# Rate limiting and CORS
# ----------------------------------------------------------------------

# Sliding window for per-IP rate limiting, in milliseconds.
RATE_LIMIT_WINDOW_MS=60000

# Max requests per IP per window.
RATE_LIMIT_MAX=30

# Single allowed origin for cross-origin requests. Leave empty to
# disable CORS (recommended when the SPA and API share an origin).
CORS_ORIGIN=


# ----------------------------------------------------------------------
# Frontend build-time flags
#
# These are baked into the Vite bundle at build time, not read at
# runtime. Change them and rebuild the image (or re-run `npm run build
# -w frontend`) for them to take effect.
# ----------------------------------------------------------------------

# Base path for the built assets. Mirror BASE_PATH when the app is
# reverse-proxied under a sub-path. For GitHub Pages project sites,
# set this to `/<repo>/`, e.g. `/passy/`.
VITE_BASE_PATH=/

# Which generator tab is selected on first visit. One of the entries
# from ALLOWED_SAVE_TYPES.
VITE_DEFAULT_MODE=password

# JSON array of custom generator presets. See README for the schema.
VITE_PRESETS=

# Max entries kept in the in-browser history.
VITE_MAX_HISTORY=50


# ----------------------------------------------------------------------
# Server configuration (non-env-specific)
# ----------------------------------------------------------------------

# Which generator modes are enabled. Comma-separated list; the default
# enables all seven. Remove modes you do not want to expose, e.g. drop
# `totp` on a deployment where TOTP secrets should never be generated.
ALLOWED_SAVE_TYPES=password,passphrase,pin,uuid,pronounceable,totp,special
